# ============================================================================
# Job-Agent environment example. Copy to .env and adjust. NEVER commit .env.
# ============================================================================

# ---- App ----
APP_NAME="Job-Agent API"
APP_VERSION="0.1.0"
ENVIRONMENT="development"

# ---- Database ----
# Phase 1 default: SQLite (runs with no extra services).
DATABASE_URL="sqlite:///./job_agent.db"
# Later, with Docker Compose Postgres + pgvector, switch to:
# DATABASE_URL="postgresql+psycopg://job_agent:job_agent@localhost:5432/job_agent"

# ---- CORS (frontend origins, comma-separated) ----
BACKEND_CORS_ORIGINS="http://localhost:3000"

# ---- Local AI (Phase 2+, not used in Phase 1) ----
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen3:8b"
EMBEDDING_MODEL="nomic-embed-text"

# ---- Automation (Phase 11) ----
AUTO_SUBMIT="false"

# ---- Frontend (see frontend/.env.local) ----
# NEXT_PUBLIC_API_URL="http://localhost:8000"
